{
  "name": "drishti-kon",
  "version": "0.1.0",
  "private": true,
  "description": "DrishtiKon - College Community Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "postinstall": "node scripts/patch-next.js",
    "db:migrate": "cd apps/api && ./mvnw flyway:migrate",
    "db:reset": "cd apps/api && ./mvnw flyway:clean flyway:migrate",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@turbo/gen": "^1.10.12",
    "turbo": "latest",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.0.0"
}
